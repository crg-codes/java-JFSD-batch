Ex: 6

for(i=0;i<n;i++)  // n
{
  for(j=1;j<n;j=j*2)// log n * n
  {
     //body   // log n * n
  }

}

Time complexity = 2nlog n + n

O(nlog n)

for(i=0;i<n;i++) - O(n)
for(i=0;i<n;i=i+2)- O(n/2)- O(n) 
for(i=b;i>1;i--) - O(n)
for(j=1;j<n;j=j*2)- O(log2 n)
for(j=1;j<n;j=j*3)- O(log3 n)
for(j=1;j*j<n;j++)- O(Vn)



