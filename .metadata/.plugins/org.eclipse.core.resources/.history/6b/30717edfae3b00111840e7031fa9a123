package com.test;

import java.util.ArrayList;
import java.util.Arrays;
import java.util.List;
import java.util.stream.Collectors;

//Functional Interface
interface MathOperation
{
	int operate(int a,int b);
}

public class LambdaExpressionExample {

	public static void main(String[] args) {
		
		
		MathOperation add=(a,b) -> a+b;
		System.out.println(add.operate(10, 20));
		
		MathOperation multuply=(a,b)->a*b;
		System.out.println(multuply.operate(10, 20));
		
		
		List<String> names=new ArrayList<String>(Arrays.asList("John","Alice","Bob"));
		names.forEach(name -> System.out.println(name));
		
		List<Integer> integers=Arrays.asList(1,2,3,4,5,6,7);
		
		List<Integer> evenNumbers=integers.stream()
				    .filter(n -> n%2 == 0)
				    .collect(Collectors.toList());
		
		System.out.println(evenNumbers);
				    
		
	}

}
