package com.test;
interface Sayable
{
	void say();
}


public class ReferenceToInstanceMethod {
	
	public void saySomthing()
	{
		System.out.println("Hello world!!");
	}

	public static void main(String[] args) {
		
		ReferenceToInstanceMethod instanceMethod=new ReferenceToInstanceMethod();
		

		Sayable sayable=instanceMethod::saySomthing;
		
		sayable.say();
	}

}
