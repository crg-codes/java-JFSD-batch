package com.thread;
public class SleepExample extends Thread {

	public SleepExample(String msg)
	{
		super(msg);
	}
	
	
	public void run()
	{
		for(int i=0;i<5;i++)
		{
			System.out.println(Thread.currentThread().getName()+
					" is running. Iteration:"+i);
			
			try 
			{
				Thread.sleep(1000,10);
			} catch (InterruptedException e) {
				
				e.printStackTrace();
			}
		}
	}
	public static void main(String[] args) {
		
		SleepExample t1=new SleepExample("Thread - 1");
		SleepExample t2=new SleepExample("Thread - 2");
		
		t1.start();
		t2.start();
		
		

	}

}
